shui:autoCompleteEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:AutoCompleteEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isIRI ;
    shui:shapesGraphShape shui:prefersAutoCompleteEditor, shui:hasClassConstraint ;
.

