@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shui: <http://www.w3.org/ns/shacl-ui#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

#### TextFieldEditor

shui:textFieldEditorScoreMinus1
    a shui:WidgetScore ;
    shui:widget shui:TextFieldEditor ;
    shui:score -1 ;
    shui:shapesGraphShape shui:isSingleLineFalse ;
.

shui:textFieldEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:TextFieldEditor ;
    shui:score 40 ;
    shui:shapesGraphShape shui:prefersTextFieldEditor ;
.

shui:textFieldEditorScore30
    a shui:WidgetScore ;
    shui:widget shui:TextFieldEditor ;
    shui:score 30 ;
    shui:dataGraphShape shui:isString ;
.

shui:textFieldEditorScore10
    a shui:WidgetScore ;
    shui:widget shui:TextFieldEditor ;
    shui:score 10 ;
    shui:shapesGraphShape shui:hasDatatypeStringConstraint ;
.

shui:textFieldEditorScore0
    a shui:WidgetScore ;
    shui:widget shui:TextFieldEditor ;
    shui:score 0 ;
    shui:shapesGraphShape shui:hasCustomDatatype ;
.

shui:prefersTextFieldEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:TextFieldEditor ;
    ] ;
.


