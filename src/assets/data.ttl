@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix schema: <http://schema.org/>.
@prefix ex: <http://example.org/>.

ex:alice a foaf:Person ;
    foaf:name "Alice" ;
    ex:profession ex:Engineer ;
    ex:bornIn ex:Belgium ;
    schema:address ex:alicesAddress ;
.

ex:alicesAddress a schema:PostalAddress ;
    schema:streetAddress "123 Main St" ;
    schema:addressLocality "Brussels" ;
    schema:addressRegion "Brussels-Capital Region" ;
    schema:postalCode "1000" ;
    schema:addressCountry "Belgium" ;
.

ex:engDept a ex:Department ;
    ex:member ex:alice ;
    rdfs:label "Engineering Department" .


ex:Engineer a ex:Profession ;
    rdfs:label "Engineer" ;
    rdfs:comment "A person who designs, builds, or maintains engines, machines, or structures."
.

ex:Doctor a ex:Profession ;
    rdfs:label "Doctor" ;
    rdfs:comment "A person who is qualified to treat people who are ill."
.

ex:Researcher a ex:Profession ;
    rdfs:label "Researcher" ;
    rdfs:comment "A person who conducts research in a particular field."
.

ex:Salesperson a ex:Profession ;
    rdfs:label "Salesperson" ;
    rdfs:comment "A person who sells goods or services."
.

ex:Physicist a ex:Profession ;
    rdfs:label "Physicist" ;
    rdfs:comment "A person who studies or practices physics."
.

ex:Physiotherapist a ex:Profession ;
    rdfs:label "Physiotherapist" ;
    rdfs:comment "A person who helps patients improve their physical mobility and manage pain."
.

ex:Belgium a ex:Country ;
    rdfs:label "Belgium" ;
    rdfs:comment "A country in Western Europe."
.

ex:ProfessionShape a sh:PropertyShape ;
    sh:path ex:profession ;
    sh:class ex:Profession ;
    sh:name "Profession" ;
.

ex:BornInShape a sh:PropertyShape ;
    sh:path ex:bornIn ;
    sh:class ex:Country ;
    sh:name "Country of Birth" ;
.
